{"id":12,"name":"Bookshelf","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<\\n[1]>(There's some folktale books.)"]},{"code":102,"indent":0,"parameters":[["The shining light","Bluebirb","Leave"],2,0,2,0]},{"code":402,"indent":0,"parameters":[0,"The shining light"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(You quickly open the book...)"]},{"code":250,"indent":1,"parameters":[{"name":"Book2","volume":90,"pitch":100,"pan":0}]},{"code":221,"indent":1,"parameters":[]},{"code":105,"indent":1,"parameters":[2,false]},{"code":405,"indent":1,"parameters":["The shining light"]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["There was once a small village by the sea. "]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["It was a very pretty village, sometimes, people would"]},{"code":405,"indent":1,"parameters":["come to visit. Just to see the hills."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["In the center of the village, there was a fire that "]},{"code":405,"indent":1,"parameters":["never faded."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["It had been there for many generations."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["But one day, a terrible famine struck the land."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["The hills began to dry out and the crops would fade."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["The fire still shone bright."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Eventually, everyone had to leave the village. For food"]},{"code":405,"indent":1,"parameters":["and for clothing."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Over time, the village faded."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["The houses covered in vines and the market completely"]},{"code":405,"indent":1,"parameters":["out of sight."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["But still shining bright in the center was the ancient"]},{"code":405,"indent":1,"parameters":["fire. It is said you can see it from the next village."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["It became the symbol for stability and eternal life."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["But the village never returned."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["THE END"]},{"code":222,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Bluebirb"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(You quickly open the book...)"]},{"code":250,"indent":1,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":221,"indent":1,"parameters":[]},{"code":105,"indent":1,"parameters":[2,false]},{"code":405,"indent":1,"parameters":["Bluebirb"]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Once upon a time, a bluebird sat by the window of a "]},{"code":405,"indent":1,"parameters":["mansion."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Every single day, it would sit and sing as the child"]},{"code":405,"indent":1,"parameters":["of house would smile and listen."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["At the time, she was only 4 years old."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["As time went on, the bluebird would continue singing"]},{"code":405,"indent":1,"parameters":["day after day. "]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["One day, the girl, who was only 6 at the time, called"]},{"code":405,"indent":1,"parameters":["out to the bird with a loving voice, \"Bluebirb!\", she "]},{"code":405,"indent":1,"parameters":["smiled, \"Please, sing me a lullaby.\"."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["So the bird did, knowing that the child was very tired."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["One day, the girl stopped coming."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["The bird eventually gave up and left."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["One day, the girl, who was now a woman, was riding to"]},{"code":405,"indent":1,"parameters":["a faraway town for a buisness deal."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["As she was heading to the town, she was attacked by "]},{"code":405,"indent":1,"parameters":["a small group of bandits. They took all she had and"]},{"code":405,"indent":1,"parameters":["threw her into the forest."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Lost, alone and scared. She screamed and cried for"]},{"code":405,"indent":1,"parameters":["someone to help her. "]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["No-one came."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["She ran and ran, trying to escape. But she bashed into"]},{"code":405,"indent":1,"parameters":["a tree."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Getting herself up, she turned around back towards the"]},{"code":405,"indent":1,"parameters":["forest."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["To her suprise, it was the little bluebird."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["It started to fly away, so she chased after it. Leading"]},{"code":405,"indent":1,"parameters":["her back home where she started."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["\"Bluebirb...\", she cried, looking like a lost child,"]},{"code":405,"indent":1,"parameters":["\"thank you so much.\"."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["With that, the bluebird left, but still visited the "]},{"code":405,"indent":1,"parameters":["woman every day, just like before."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["THE END"]},{"code":222,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[2,"Leave"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":3,"y":7}
