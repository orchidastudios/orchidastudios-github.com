{"id":1,"name":"Bookshelf","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<\\n[1]>(There are books on the shelves.)"]},{"code":102,"indent":0,"parameters":[["The parable of Klara Maple part 2","Cancel"],1,0,2,1]},{"code":402,"indent":0,"parameters":[0,"The parable of Klara Maple part 2"]},{"code":250,"indent":1,"parameters":[{"name":"Book2","volume":100,"pitch":100,"pan":0}]},{"code":221,"indent":1,"parameters":[]},{"code":105,"indent":1,"parameters":[2,false]},{"code":405,"indent":1,"parameters":["I fell right into the receptionist's desk as I entered."]},{"code":405,"indent":1,"parameters":["But, without a word, I ran as fast as I could just to "]},{"code":405,"indent":1,"parameters":["get to my station."]},{"code":405,"indent":1,"parameters":[" "]},{"code":405,"indent":1,"parameters":["\"Maybe there's still time!\", I thought, but I knew deep"]},{"code":405,"indent":1,"parameters":["down that this was false hope. "]},{"code":405,"indent":1,"parameters":["As I ran hopelessly through the endless corridor passing"]},{"code":405,"indent":1,"parameters":["room after room and pushing past any disruptions."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Finally! I made it! Three hours late but seven hours "]},{"code":405,"indent":1,"parameters":["before closing."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["I thought I would get away with this, especially since"]},{"code":405,"indent":1,"parameters":["my boss didn't appear anywhere on my long journey."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["Joyfully, I stood at my workplace, prepared to start when,"]},{"code":405,"indent":1,"parameters":["all of a sudden, I heard a crash."]},{"code":405,"indent":1,"parameters":["My boss was stood at the end of the production line,"]},{"code":405,"indent":1,"parameters":["frowning and mumbling. "]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["I didn't say anything. But the conveyor belt had stopped"]},{"code":405,"indent":1,"parameters":["moving. I quickly turned around, all of my co-workers "]},{"code":405,"indent":1,"parameters":["had disappeared from the factory. It was just me and..."]},{"code":405,"indent":1,"parameters":["him."]},{"code":405,"indent":1,"parameters":[""]},{"code":405,"indent":1,"parameters":["I felt my hands shake, but just as I felt the slightest"]},{"code":405,"indent":1,"parameters":["bit reassured. He...my boss...opened his mouth."]},{"code":222,"indent":1,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\n<\\n[1]>(Damn.)"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Cancel"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":3,"y":6},
