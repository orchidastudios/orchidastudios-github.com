{"id":3,"name":"The Akuji project","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["                 The revival recipe"]},{"code":401,"indent":0,"parameters":["                   Cae Moneloria"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Ingredients:"]},{"code":401,"indent":0,"parameters":["-\t1 Bottle’o’life"]},{"code":401,"indent":0,"parameters":["-\t2 Revival herbs"]},{"code":401,"indent":0,"parameters":["-\t1 Lovely dumpling"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["-\t5 Magic cheese"]},{"code":401,"indent":0,"parameters":["-\t1 Luck potion"]},{"code":401,"indent":0,"parameters":["-\t1 Jade flower"]},{"code":401,"indent":0,"parameters":["-\t1 teleportation stone"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["-\tBody of a human mage"]},{"code":401,"indent":0,"parameters":["(aura must match that of the deceased person,"]},{"code":401,"indent":0,"parameters":["or this recipe won't work)"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["The ingredients, except for the body,"]},{"code":401,"indent":0,"parameters":["must be combined together into a single glass."]},{"code":401,"indent":0,"parameters":["The glass can be as big as you want."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["You must start up my machine,"]},{"code":401,"indent":0,"parameters":["it is in the secret forest near the new capital"]},{"code":401,"indent":0,"parameters":["of Alaudia."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I'm sure, if you're reading this,"]},{"code":401,"indent":0,"parameters":["you will be able to find it."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["You must bring the bottle with you,"]},{"code":401,"indent":0,"parameters":["as well as the dead body of the mage."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["You must then say the phrase,"]},{"code":401,"indent":0,"parameters":["'I summon you, Clem Atis.'"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Clem Atis will be summoned,"]},{"code":401,"indent":0,"parameters":["and then he will take you to your loved one."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["And he will be my most powerful creature of all."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I cannot achieve it during my lifetime,"]},{"code":401,"indent":0,"parameters":["but I must have faith that one of my future"]},{"code":401,"indent":0,"parameters":["followers will take it on themselves to bring "]},{"code":401,"indent":0,"parameters":["me back to life."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Or else, I suppose, death will truly be"]},{"code":401,"indent":0,"parameters":["goodbye."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Sayu>(A sacrifice? This seems immoral.)"]},{"code":101,"indent":0,"parameters":["Aneca",0,0,2]},{"code":401,"indent":0,"parameters":["\\nr<Aneca>So you have to kill in order to bring"]},{"code":401,"indent":0,"parameters":["somebody back to life? Ironic."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":3,"y":7},
{"id":4,"name":"The Akuji project","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["                 The secret forest"]},{"code":401,"indent":0,"parameters":["                   Cae Moneloria"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["If you are reading this book, I assume that you are"]},{"code":401,"indent":0,"parameters":["interested in using my revival recipe."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["If not, then I recommend that you put this book back"]},{"code":401,"indent":0,"parameters":["where you found it."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I assure you, it is pointless to read through."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["If you intend on making your way into the secret"]},{"code":401,"indent":0,"parameters":["forest to revive a loved one, please continue"]},{"code":401,"indent":0,"parameters":["reading."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["There is a monster that I put in the way,"]},{"code":401,"indent":0,"parameters":["to keep out the unworthy."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I ensured he would never kill a human,"]},{"code":401,"indent":0,"parameters":["so just keep on trying."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["And then follow my recipe, simple."]},{"code":0,"indent":0,"parameters":[]}],"