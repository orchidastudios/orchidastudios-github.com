{"id":7,"name":"Part 9","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["For my dear Neon,"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["That sounds strange, I'm aware."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I am writing to let you know about my suspicions"]},{"code":401,"indent":0,"parameters":["against Eayania. She might be a double-agent of"]},{"code":401,"indent":0,"parameters":["sorts."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Why someone would be spying on us, I don't know."]},{"code":401,"indent":0,"parameters":["But keep it in mind whenever you're with her."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Keep her close as possible, if you catch her communicating"]},{"code":401,"indent":0,"parameters":["with someone other than us, report to me immediately."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Please write back to me."]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["- Valo"]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":3,"y":18},
{"id":8,"name":"The Akuji project","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["                 The Akuji project"]},{"code":401,"indent":0,"parameters":["                   Cae Moneloria"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["'The Akuji project', it is a dramatic name,"]},{"code":401,"indent":0,"parameters":["isn't it?"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I believe it to be very fitting for its"]},{"code":401,"indent":0,"parameters":["given purpose."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["The name Akuji means 'Dead and Awake',"]},{"code":401,"indent":0,"parameters":["and it is also the name of my late husband."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["He was the reason I began this project,"]},{"code":401,"indent":0,"parameters":["but my goals have since became more ambitious."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I wish to keep it as a failsafe, of sorts,"]},{"code":401,"indent":0,"parameters":["to ensure that if I die, somebody else"]},{"code":401,"indent":0,"parameters":["will bring me back to the land of the"]},{"code":401,"indent":0,"parameters":["living."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I must continue my research, but it is going"]},{"code":401,"indent":0,"parameters":["nicely so far."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["And, as was the advise I got from my dear"]},{"code":401,"indent":0,"parameters":["assistant, who I will call 'Al'."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I should not concern myself with minor things"]},{"code":401,"indent":0,"parameters":["such as the amount of sacrifices required."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["It's sad but true, this development cannot be"]},{"code":401,"indent":0,"parameters":["stopped."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":7,"y":15}
