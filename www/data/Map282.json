{"id":5,"name":"Part 7","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["December 3rd, 1021:"]},{"code":401,"indent":0,"parameters":["We found a mage, the same type as Chiwa!"]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["It's a little girl, only eight years of age,"]},{"code":401,"indent":0,"parameters":["but this is only in the name of reviving Chiwa."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Although, the guide says that the ritual only works"]},{"code":401,"indent":0,"parameters":["if the mage sacrificed is over twelve years of age."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I hope to find somebody sooner, but she will serve"]},{"code":401,"indent":0,"parameters":["as an excellent backup, I believe."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["She comes from the low-end of Caesitia,"]},{"code":401,"indent":0,"parameters":["but I believe she is not of Caesite descent."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["Regardless of her lineage, I convinced the king that"]},{"code":401,"indent":0,"parameters":["she's my little sister. My father was a friend of"]},{"code":401,"indent":0,"parameters":["his, you see."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["He owed him a huge favour, so it was easy to convince"]},{"code":401,"indent":0,"parameters":["him to take her into the palace."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["We'll take her back if we need her for the ritual,"]},{"code":401,"indent":0,"parameters":["hopefully she'll stop following me now."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["- Valo"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Sayu>(What happens next, I wonder.)"]},{"code":250,"indent":0,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["December 23rd, 1021:"]},{"code":401,"indent":0,"parameters":["This girl won't stop following us around,"]},{"code":401,"indent":0,"parameters":["she got hold of a bunch of teleport stones,"]},{"code":401,"indent":0,"parameters":["somehow."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I can't help but feel that the others are getting fairly"]},{"code":401,"indent":0,"parameters":["attached to her, this could cause a problem in the"]},{"code":401,"indent":0,"parameters":["future, if I decide to go through with the backup."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["She has no family. This must be why she got so attached"]},{"code":401,"indent":0,"parameters":["to us so easily."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I hoped the king would be enough,"]},{"code":401,"indent":0,"parameters":["but apparently that plan was a failure."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["At this point, the three of them are going to adopt"]},{"code":401,"indent":0,"parameters":["her."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["But I suppose this means that I need to find a "]},{"code":401,"indent":0,"parameters":["replacement sacrifice, fast."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["I need to test the type of every mage I meet."]},{"code":401,"indent":0,"parameters":["I must bring Chiwa back."]},{"code":101,"indent":0,"parameters":["",0,1,1]},{"code":401,"indent":0,"parameters":["- Valo"]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":9,"y":7},
