{"id":10,"name":"EV010","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":105,"indent":0,"parameters":[1,false]},{"code":405,"indent":0,"parameters":["Some people"]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["Some people think that they are better than others."]},{"code":405,"indent":0,"parameters":["Morally superior, righteous fighters."]},{"code":405,"indent":0,"parameters":["They do not want to be proven wrong."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["Any mortal or immortal who questions what they say,"]},{"code":405,"indent":0,"parameters":["will be dismissed as a heartless, terrible person."]},{"code":405,"indent":0,"parameters":["They won't even listen."]},{"code":405,"indent":0,"parameters":["All they feel towards them is hatred."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["They don't even consider that they might be wrong."]},{"code":405,"indent":0,"parameters":["They don't care that they are harming people."]},{"code":405,"indent":0,"parameters":["They like the feeling of being morally right,"]},{"code":405,"indent":0,"parameters":["without considering if they truly are."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["They want others to be bad people."]},{"code":405,"indent":0,"parameters":["They want others to be mistreated."]},{"code":405,"indent":0,"parameters":["They pretend to be angry, but this is exactly what"]},{"code":405,"indent":0,"parameters":["they wanted:"]},{"code":405,"indent":0,"parameters":["To be the victim."]},{"code":405,"indent":0,"parameters":["Any real issues are ignored in place of outrage."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["They don't care."]},{"code":405,"indent":0,"parameters":["They think they have to be right."]},{"code":405,"indent":0,"parameters":["Very few have the guts to openly disagree, "]},{"code":405,"indent":0,"parameters":["if they do they are bombarded with insults"]},{"code":405,"indent":0,"parameters":["and violence."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["Some people think this is okay."]},{"code":405,"indent":0,"parameters":["That all of these people are terrible anyway,"]},{"code":405,"indent":0,"parameters":["for daring to say something other than what they"]},{"code":405,"indent":0,"parameters":["believe, and want to believe."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["But they are still the 'victims'."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["They say that violence is never okay, unless it's "]},{"code":405,"indent":0,"parameters":["someone they dislike."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["But, it's okay, they're the enemy. "]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["Clearly, they deserve it."]},{"code":405,"indent":0,"parameters":[""]},{"code":405,"indent":0,"parameters":["Clearly, they're beneath me."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":0,"y":9}
